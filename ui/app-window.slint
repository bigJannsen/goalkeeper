import { Button, HorizontalBox, LineEdit, ListView, VerticalBox } from "std-widgets.slint";

export struct GoalRow {
           id: int,
           title: string,
           details: string,
           done: bool,
           status_text: string,
       }

export component AppWindow inherits Window {

    in-out property <int> current-year: 2026;            // aktives Jahr
    in property <[GoalRow]> goal-items;                  // Liste aus C++

    in property <int> total-goals: 0;                    // Statistik gesamt
    in property <int> completed-goals: 0;                // erledigt
    in property <float> completion-rate: 0;              // Fortschritt

    in-out property <bool> show-goals-page: true;        // Page toggle

    in-out property <bool> show-search: false;           // Suche sichtbar
    in-out property <string> search-text: "";            // Suchtext

    in-out property <int> expanded-goal-id: -1;          // aufgeklapptes Goal
    in-out property <int> selected-goal-id: -1;          // ausgewählt

    in-out property <bool> show-create-dialog: false;    // Create Dialog
    in-out property <bool> show-detail-dialog: false;    // Detail Dialog
    in-out property <bool> show-delete-confirm-dialog: false; // Delete Dialog

    in-out property <string> draft-title: "";            // Form Titel
    in-out property <string> draft-details: "";          // Form Details
    in-out property <int> draft-year: root.current-year; // Form Jahr

    callback add-goal(string);                           // einfaches Add
    callback year-changed(int);                          // Jahr wechseln

    callback open-create-dialog();                       // UI → Dialog öffnen
    callback open-detail-dialog(int);                    // Details öffnen
    callback request-toggle-status(int);                 // Done toggle
    callback request-delete-goal(int);                   // löschen
    callback request-save-detail(int, string, string, int); // speichern
    callback request-create-goal(string, string, int);   // erstellen

    callback search-text-changed();                      // Suche triggern

    default-font-family: "Arial";
    default-font-size: 14px;

    min-width: 760px;
    min-height: 560px;
    title: "Goalkeeper";
    background: #0c1018;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #0c1018;
        //clip: true;

        HorizontalBox {
            width: parent.width;
            height: parent.height;
            spacing: 14px;
            padding: 14px;

            Rectangle {
                width: 170px;
                background: #141b28;
                border-radius: 12px;
                border-width: 1px;
                border-color: #222c40;
                //clip: false;

                VerticalBox {
                    x: 14px;
                    y: 14px;
                    width: parent.width - 28px;
                    height: parent.height - 28px;
                    spacing: 10px;

                    Text {
                        text: "GOALKEEPER";
                        color: #7f8ea8;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Jahr \{root.current-year}";
                        color: #dce6ff;
                        font-size: 20px;
                        font-weight: 700;
                    }

                    Rectangle {
                        height: 1px;
                        background: #26314a;
                    }

                    Rectangle {
                        height: 44px;
                        background: root.show-goals-page ? #3f67ff : #1a2234;
                        border-radius: 10px;

                        Button {
                            width: parent.width;
                            height: parent.height;
                            text: "Goals";
                            clicked => { root.show-goals-page = true; }
                        }
                    }

                    Rectangle {
                        height: 44px;
                        background: root.show-goals-page ? #1a2234 : #3f67ff;
                        border-radius: 10px;

                        Button {
                            width: parent.width;
                            height: parent.height;
                            text: "Statistics";
                            clicked => { root.show-goals-page = false; }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #00000000;
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: #111827;
                border-radius: 12px;
                border-width: 1px;
                border-color: #222c40;

                if (root.show-goals-page) : Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: #00000000;

                    VerticalBox {
                        x: 18px;
                        y: 18px;
                        width: parent.width - 36px;
                        height: parent.height - 36px;
                        spacing: 14px;

                        Text {
                            text: "Goals Dashboard";
                            color: #f2f5ff;
                            font-size: 24px;
                            font-weight: 700;
                        }

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                width: 94px;
                                text: "< Jahr";
                                clicked => {
                                    root.year-changed(root.current-year - 1);
                                }
                            }

                            Rectangle {
                                background: #1a2234;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: #283550;
                                min-width: 150px;
                                min-height: 36px;

                                Text {
                                    x: 12px;
                                    y: 9px;
                                    text: "Aktives Jahr: \{root.current-year}";
                                    color: #dce6ff;
                                }
                            }

                            Button {
                                width: 94px;
                                text: "Jahr >";
                                clicked => {
                                    root.year-changed(root.current-year + 1);
                                }
                            }
                        }

                        Rectangle {
                            height: 48px;
                            background: #00000000;

                            // SUCHBEREICH LINKS
                            Rectangle {
                                x: 0;
                                y: 6px;
                                width: parent.width - 160px;
                                height: 36px;
                                background: #00000000;

                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 8px;
                                    background: #22304a;
                                    border-width: 1px;
                                    border-color: #334566;

                                    TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => {
                                            root.show-search = !root.show-search;
                                            if (!root.show-search) {
                                                root.search-text = "";
                                            }
                                        }
                                    }

                                    Text {
                                        x: (parent.width - self.preferred-width) / 2;
                                        y: (parent.height - self.preferred-height) / 2;
                                        text: "🔍";
                                        font-size: 16px;
                                    }
                                }

                                if (root.show-search) : Rectangle {
                                    x: 44px;
                                    y: 0;
                                    width: parent.width - 44px;
                                    height: 36px;
                                    background: #00000000;

                                    search-input := LineEdit {
                                        x: 0;
                                        y: 0;
                                        width: parent.width - 36px;
                                        height: 36px;
                                        text: root.search-text;
                                        placeholder-text: "Ziele suchen";
                                        edited => {
                                            root.search-text = self.text;
                                        }
                                    }

                                    Rectangle {
                                        x: parent.width - 30px;
                                        y: 3px;
                                        width: 30px;
                                        height: 30px;
                                        border-radius: 6px;
                                        background: #7c2e3f;
                                        border-width: 1px;
                                        border-color: #a24459;

                                        TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            clicked => {
                                                root.show-search = false;
                                                root.search-text = "";
                                            }
                                        }

                                        Text {
                                            x: (parent.width - self.preferred-width) / 2;
                                            y: (parent.height - self.preferred-height) / 2;
                                            text: "X";
                                            color: #ffffff;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }
                                    }
                                }
                            }

                            // ERSTELLEN BUTTON RECHTS
                            Rectangle {
                                x: parent.width - 152px;
                                y: 6px;
                                width: 140px;
                                height: 36px;
                                background: #1f7a4b;
                                border-radius: 8px;
                                border-width: 1px;
                                border-color: #2a9a61;

                                Button {
                                    width: parent.width;
                                    height: parent.height;
                                    text: "Erstellen";
                                    clicked => {
                                        root.open-create-dialog();
                                    }
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: #0f1625;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: #273550;

                            ListView {
                                width: parent.width;
                                height: parent.height;

                                for goal-row in root.goal-items : Rectangle {
                                    height: root.expanded-goal-id == goal-row.id ? 220px : 118px;

                                    background: #00000000;

                                    Rectangle {
                                        x: 10px;
                                        y: 6px;
                                        width: parent.width - 20px;
                                        height: parent.height - 12px;
                                        background: #182238;
                                        border-radius: 10px;
                                        border-width: 1px;
                                        border-color: #2a3a59;

                                        Text {
                                            x: 12px;
                                            y: 10px;
                                            text: "ID: \{goal-row.id}";
                                            color: #91a3c6;
                                            font-size: 12px;
                                        }

                                        Text {
                                            x: 12px;
                                            y: 32px;
                                            width: parent.width - 190px;
                                            text: goal-row.title;
                                            color: #ecf2ff;
                                            font-size: 15px;
                                            font-weight: 600;
                                        }

                                        Rectangle {
                                            x: parent.width - 112px;
                                            y: (parent.height - 30px) / 2;
                                            width: 96px;
                                            height: 30px;
                                            background: goal-row.done ? #1f7a4b : #7c2e3f;
                                            border-radius: 15px;

                                            TouchArea {
                                                width: parent.width;
                                                height: parent.height;
                                                clicked => {
                                                    root.request-toggle-status(goal-row.id);
                                                }
                                            }

                                            Text {
                                                x: (parent.width - self.preferred-width) / 2;
                                                y: (parent.height - self.preferred-height) / 2 - 1px;
                                                text: goal-row.status_text;
                                                color: #f6f9ff;
                                                font-size: 13px;
                                                font-weight: 600;
                                            }
                                        }

                                        Rectangle {
                                            x: parent.width - 152px;
                                            y: (parent.height - 30px) / 2;
                                            width: 30px;
                                            height: 30px;
                                            background: #22304a;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: #334566;

                                            TouchArea {
                                                width: parent.width;
                                                height: parent.height;
                                                clicked => {
                                                    root.selected-goal-id = goal-row.id;
                                                    root.draft-title = goal-row.title;
                                                    root.draft-details = goal-row.details;
                                                    root.draft-year = root.current-year;
                                                    root.open-detail-dialog(goal-row.id);
                                                }
                                            }

                                            Text {
                                                x: (parent.width - self.preferred-width) / 2;
                                                y: (parent.height - self.preferred-height) / 2 + 2px;
                                                text: "✎";
                                                color: #dce6ff;
                                                font-size: 14px;
                                            }
                                        }

                                        if (root.expanded-goal-id == goal-row.id) : Text {
                                            x: 12px;
                                            y: 58px;
                                            width: parent.width - 24px;
                                            text: goal-row.details == "" ? "Keine Details hinterlegt" : goal-row.details;
                                            color: #9fb0cf;
                                            font-size: 12px;
                                        }

                                        Rectangle {
                                            x: (parent.width - 36px) / 2;
                                            y: parent.height - 26px;
                                            width: 36px;
                                            height: 18px;
                                            background: #22304a;
                                            border-radius: 9px;
                                            border-width: 1px;
                                            border-color: #334566;

                                            TouchArea {
                                                width: parent.width;
                                                height: parent.height;
                                                clicked => {
                                                    if (root.expanded-goal-id == goal-row.id) {
                                                        root.expanded-goal-id = -1;
                                                    } else {
                                                        root.expanded-goal-id = goal-row.id;
                                                    }
                                                }
                                            }

                                            Text {
                                                x: (parent.width - self.preferred-width) / 2;
                                                y: parent.height - 18px;
                                                text: root.expanded-goal-id == goal-row.id ? "^" : "v";
                                                color: #dce6ff;
                                                font-size: 14px;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if (!root.show-goals-page) : Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: #00000000;

                    VerticalBox {
                        x: 18px;
                        y: 18px;
                        width: parent.width - 36px;
                        height: parent.height - 36px;
                        spacing: 12px;

                        Text {
                            text: "Statistics";
                            color: #f2f5ff;
                            font-size: 24px;
                            font-weight: 700;
                        }

                        Text {
                            text: "Uebersicht fuer Jahr \{root.current-year}";
                            color: #9aa8c1;
                            font-size: 14px;
                        }

                        HorizontalBox {
                            spacing: 10px;

                            Rectangle {
                                vertical-stretch: 1;
                                min-height: 110px;
                                background: #17233a;
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: #273957;

                                Text {
                                    x: 12px;
                                    y: 14px;
                                    text: "Ziele insgesamt";
                                    color: #9fb0cf;
                                    font-size: 13px;
                                }

                                Text {
                                    x: 12px;
                                    y: 42px;
                                    text: "\{root.total-goals}";
                                    color: #f3f6ff;
                                    font-size: 34px;
                                    font-weight: 700;
                                }
                            }

                            Rectangle {
                                vertical-stretch: 1;
                                min-height: 110px;
                                background: #17233a;
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: #273957;

                                Text {
                                    x: 12px;
                                    y: 14px;
                                    text: "Erledigt";
                                    color: #9fb0cf;
                                    font-size: 13px;
                                }

                                Text {
                                    x: 12px;
                                    y: 42px;
                                    text: "\{root.completed-goals}";
                                    color: #78d39f;
                                    font-size: 34px;
                                    font-weight: 700;
                                }
                            }
                        }

                        Rectangle {
                            min-height: 130px;
                            background: #17233a;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: #273957;

                            Text {
                                x: 12px;
                                y: 14px;
                                text: "Fortschritt";
                                color: #9fb0cf;
                                font-size: 13px;
                            }

                            Text {
                                x: 12px;
                                y: 40px;
                                text: "\{(root.completion-rate * 100)}% abgeschlossen";
                                color: #f3f6ff;
                                font-size: 22px;
                                font-weight: 700;
                            }

                            Rectangle {
                                x: 12px;
                                y: 84px;
                                width: parent.width - 24px;
                                height: 20px;
                                background: #0f1625;
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: #293959;

                                Rectangle {
                                    x: 2px;
                                    y: 2px;
                                    width: (parent.width - 4px) * root.completion-rate;
                                    height: parent.height - 4px;
                                    background: #4f6dff;
                                    border-radius: 8px;
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: #00000000;
                        }
                    }
                }
            }
        }
    }
}
